{
  "name": "@rackula/api",
  "version": "26.6.5",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "dev:worker": "wrangler dev",
    "start": "bun src/index.ts",
    "test": "bun test",
    "test:workers": "vitest run --config vitest.workers.config.ts",
    "build:worker": "wrangler deploy --dry-run --outdir dist-worker",
    "typecheck": "tsc --noEmit"
  },
  "overrides": {
    "hono": "^4.12.27",
    "@hono/node-server": "^1.19.10",
    "defu": "^6.1.5"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "better-auth": "^1.6.23",
    "hono": "^4.12.27",
    "jose": "^6.2.3",
    "js-yaml": "^4.3.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.17.0",
    "@types/bun": "^1.3.14",
    "@types/js-yaml": "^4.0.9",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3",
    "vitest": "4.1.9",
    "wrangler": "^4.106.0"
  }
}
